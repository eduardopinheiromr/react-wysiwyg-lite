{
	"name": "react-wysiwyg-lite",
	"version": "0.3.0",
	"description": "Lightweight, extensible WYSIWYG editor for React. useState-first API, zero dependencies.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.cjs"
			}
		},
		"./styles.css": "./dist/styles.css"
	},
	"files": ["dist"],
	"sideEffects": ["*.css"],
	"scripts": {
		"build": "vite build && cp src/styles.css dist/styles.css && cp src/styles.css.d.ts dist/styles.css.d.ts",
		"prepublishOnly": "npm run build",
		"test": "vitest",
		"test:run": "vitest run",
		"coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.4.0",
		"@testing-library/react": "^16.0.0",
		"@testing-library/user-event": "^14.5.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.0.0",
		"jsdom": "^24.0.0",
		"react": "^18.3.0",
		"react-dom": "^18.3.0",
		"typescript": "^5.5.0",
		"vite": "^5.0.0",
		"vite-plugin-dts": "^4.0.0",
		"vitest": "^2.0.0"
	},
	"keywords": [
		"react",
		"wysiwyg",
		"editor",
		"rich-text",
		"typescript",
		"contenteditable"
	],
	"license": "MIT"
}
